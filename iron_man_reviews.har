            "text": "{\n  \"hbbtv.js\": \"sha384-FToo57AOiAs3WCtyVfMprHVIM8uyAYqxRGFiJG5Dt/bJnQ54bN/SRZFlafl16gZg\",\n  \"otBannerSdk.js\": \"sha384-DiRhSiGBvSMcjWKnOcJQfLFss85yfzjZJ2ylu1syWGiOSqff9VT2GG7FW1NwMxdt\",\n  \"otConfirmDialog.js\": \"sha384-7v41ysMI+B8xqApmCloQZgcD6r9PnVs99cEt4n/tP1qe9CHFQ6eF2r9rTp8/Ro3e\",\n  \"otGPP.js\": \"sha384-h9IXndcwVxk1CiIDp91sw1fZgYzJeGLgPQTqxZokUgaxlnl/UJP0FiT5EoPlPYrR\",\n  \"otSDKBlock.js\": \"sha384-65yMB9oIEJp5Evyq7dymPEy7GjEEVrYhHsDGf+6ZivwUah2sucVdvq7qT6m7Op82\",\n  \"otSDKStub.js\": \"sha384-tiyh5K7l4R+WOHDhdMwOE5a37/DlvWP3cfxdjvf1DZeYm/ihl7uktyYHgQdaRvf7\",\n  \"otStub.js\": \"sha384-H6BRBqgdBqEShgpa/3SCKWpT1xVO5WSBHD7+H0sNfSZONFgu4p+jAGl9Shvgkb59\",\n  \"otTCF.js\": \"sha384-deV7aJ/y90kGLyV0cDm2UE8MOYOyxeLvwwvlBZ00hj6LWhp5PK2cL4tNhw476I+X\",\n  \"trackingTechnologies.js\": \"sha384-LnHI+IsOqtkuP2+fz7o09H38mxMLk6fIxrPjTexkdZWdKpR8BUC8xsq7QGtNfImz\"\n}"
