1||0;\\n    if(!mps._viewport || mps._viewport()[0] < 1100) {\\n      mps._l('[mps+RT] Fandango Skin FAILED (width < 1100)');\\n      mps.removeRails();\\n      return false;\\n    }\\n    if(typeof(slotele)!='object' || typeof(wrapperele)!='object' || typeof(railvars._selector)!='object' || !slotele.clientHeight || !mps._adloads[0][scaleslot]) {\\n      if(tries <= 16) {\\n        setTimeout(function(){\\n          \\/\\/mps._l('**** SKIN - AD NOT AVAILABLE TRY #'+tries,slotele);\\n          mps.rt.setFandangoSkin(railvars,tries);\\n        },250);\\n        return false;\\n      }\\n    }\\n    mps._l('[mps+RT] INITIAL Skin Height: '+railvars._selector.clientHeight+' \\/ Ad Height: '+slotele.clientHeight);\\n    railvars._selector.style.display=\\\"block\\\";\\n    railvars._selector.style.backgroundSize=\\\"100%\\\";\\n    mps._scaleAd('topbanner',scaleratio);\\n    var wrapperpadtop = parseInt(railvars._selector.style.paddingTop,10), wrapperpadbottom = parseInt(railvars._selector.style.paddingBottom,10);\\n    if(wrapperpadtop) railvars._selector.style.paddingTop = (wrapperpadtop*scaleratio)+'px';\\n    if(wrapperpadbottom) railvars._selector.style.paddingBottom = (wrapperpadbottom*scaleratio)+'px';\\n      mps._ready(function(){setTimeout(function(){ wrapperele.style.height = (railvars._selector.clientHeight+5)+'px'; },800)});\\n    mps._l('[mps+RT] NEW Skin Height: '+railvars._selector.clientHeight+' \\/ Ad Height: '+slotele.clientHeight+' \\/ Ratio: '+scaleratio+' (try #'+tries+')');\\n    return true;\\n  }\\n\\n  mps.setRails2 = mps.setRails;\\n  mps.setRails = function(railvars) {\\n    if(typeof(railvars)!='object') return false;\\n    railvars['railTarget'] = '#leaderboard_top_ad';\\n    mps.setRails2(railvars);\\n  }\\n  if(mps.getResponsiveSet && mps.setRails && mps.getResponsiveSet()=='0') {\\n    mps.setRails = function(){ mps._d('[mps.setRails] Rails are disabled for mobile viewports.') }\\n  }\\n  mps.setRailsCallback = function(railvars) {\\n    mps._d('[mps:Rails] Fandango Rails Callback Solution');\\n    if(mps._adloads && mps._adloads[0] && typeof(mps._adloads[0]['topbanner'])=='object') {\\n      \\/\\/window.console&&console.debug('**** SIZE: '+mps._adloads[0]['topbanner']['size']);\\n      jQuery('#'+mps._adloads[0].topbanner._mps.adslot).height(mps._adloads[0]['topbanner']['size'][1]);\\n      mps.setRailsCallback2(railvars);\\n    } else {\\n      mps._debug('[mps:Rails] Fandango Rails Callback Solution: NOT READY');\\n      setTimeout(mps.setRailsCallback(railvars),250);\\n    }\\n  }\\n\\n  mps.setRailsCallback2 = function(railvars) {\\n    if (typeof(railvars) === 'object' && typeof(railvars.railTarget) !== 'undefined' && typeof(railvars._selector) === 'object' && railvars._target !== 'body' && railvars.railContainer > 0) {\\n      var PADBOTTOM = 15,\\n        currentPadTop = parseInt(window.getComputedStyle(railvars._selector, null).paddingTop.replace('px', ''), 10),\\n        currentPadBottom = parseInt(window.getComputedStyle(railvars._selector, null).paddingBottom.replace('px', ''), 10),\\n        currheight = parseInt(railvars._selector.clientHeight, 10) >= 0 ? parseInt(railvars._selector.clientHeight, 10) : parseInt(mps._select(railvars._target).clientHeight, 10),\\n        targetheight = parseInt(railvars.railContainer, 10),\\n        padtop;\\n      currheight = (currheight - currentPadTop - currentPadBottom);\\n      if (targetheight > currheight) {\\n        if(typeof(mps.getResponsiveSet)=='function' && mps.getResponsiveSet()=='tablet' && Math.floor(railvars.railParallax)!=1) {\\n         railvars._selector.style.padding = (currheight == 90) ? '15px 0' : 0 ;\\n          railvars._selector.style.backgroundSize = '100%';\\n        } else {\\n          padtop = (targetheight - currheight - PADBOTTOM);\\n          debugmode.log && console.log('[mps:Rails] targetheight: '+targetheight+' currheight:'+currheight+' padtop: '+padtop+' padbottom: '+PADBOTTOM);\\n          railvars._selector.styl